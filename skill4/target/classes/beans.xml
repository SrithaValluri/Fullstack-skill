<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Course Bean -->
    <bean id="course" class="com.klu.beans.Course">
        <constructor-arg value="Spring Framework"/>
        <constructor-arg value="6"/>
    </bean>

    <!-- Student Bean -->
    <bean id="st" class="com.klu.beans.Student">

        <!-- Constructor Injection -->
        <constructor-arg value="30001"/>
        <constructor-arg value="sitha"/>
        <constructor-arg value="2024"/>
<!-- Setter Injection -->
        <property name="course" ref="course"/>
        <property name="email" value="sitha@klu.in"/>
        <property name="phoneNumber" value="8097698797"/>
</bean>
</beans>
